# Global environment overrides (optional — primary config is in configs/)
NODE_ENV=development
LOG_LEVEL=info

# Optional absolute or repo-root-relative path to platform config
# PLATFORM_CONFIG=configs/platform.yaml

# Local MySQL (LAMPP / development)
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=3306
LOCAL_DB_USER=root
LOCAL_DB_PASSWORD=raymond1
LOCAL_DB_DATABASE=medisoft_testing

# RHIE API credentials (required for services that call RHIE)
# RHIE_PASSWORD=

# Online facility database passwords (only when connecting to online replicas)
# HC_A_DB_PASSWORD=
# HC_B_DB_PASSWORD=
# HC_C_DB_PASSWORD=

# Client Registry: set executionMode in configs/platform.yaml
# clientRegistry.executionMode: shadow | production
