# Environment template — copy to .env and fill in values:
#   cp .env.example .env
#
# Prefer environment-specific sources when available:
#   cp .env.development .env   # local development
#   cp .env.production .env    # production deployment
#
# Runtime always reads .env (see packages/config/src/loader.ts).
# Primary service config remains in configs/platform.yaml.

NODE_ENV=development
LOG_LEVEL=info

# MySQL bootstrap connection (database names are discovered automatically)
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=3306
LOCAL_DB_USER=root
LOCAL_DB_PASSWORD=your-mysql-password

# Optional: pick a specific Medisoft database when multiple candidates exist
# MEDISOFT_DATABASE=medisoft_hie

# Optional absolute or repo-root-relative path to platform config
# PLATFORM_CONFIG=configs/platform.yaml

# Optional: force a fresh discovery scan
# FORCE_REDISCOVER=1

# Optional: discovery mode override (auto | local | online)
# DISCOVERY_MODE=auto

# Optional: skip discovery and use this database name directly
# LOCAL_DB_DATABASE=medisoft_hie

# RHIE API credentials (required for services that call RHIE)
# RHIE_BASE_URL=https://devhie.moh.gov.rw:5000
# RHIE_PASSWORD=your-rhie-password

# Service execution modes — set in configs/platform.yaml
# clientRegistry.executionMode: shadow | production
# visitEncounter.executionMode: shadow | production

# Tests only — skip automatic database discovery
# MEDISOFT_SKIP_DISCOVERY=1
